import { Dimensions, Font, Palette, RustInterface, Utils } from "./globals.slint";

export struct BoardState {
    board: [int],
    legal_targets: [bool],
    last_move_from: int,
    last_move_to: int,
    check_sq: int,
    dragged_piece_sq: int,
    dragged_piece: int,
}

export component Board inherits TouchArea {
    in property <BoardState> board_state;

    for i in Utils.square_count: Rectangle {
        height: Dimensions.sq_size;
        width: Dimensions.sq_size;

        // build the board (starting from the bottom left corner A1)
        background: Utils.square_color(i) == 0 ? Palette.dark_sq : Palette.light_sq;
        x: Utils.square_to_x(i, self.width);
        y: Utils.square_to_y(i, self.height);

        Text {
            color: Utils.square_color(i) == 0 ? Palette.light_sq : Palette.dark_sq;
            font-size: Font.font_size_md;
            font-weight: Font.semi_bold;
            text: mod(i, 8) == 0 ? Utils.files[floor(i / 8)] : "";
            x: 3px;
            y: 0px;
        }

        Text {
            color: Utils.square_color(i) == 0 ? Palette.light_sq : Palette.dark_sq;
            font-size: Font.font_size_md;
            font-weight: Font.semi_bold;
            text: i < 8 ? Utils.ranks[i] : "";
            x: parent.width - 13px;
            y: parent.height - 22px;
        }
        Rectangle {
            background: board_state.legal_targets[i] ? Palette.legal_sq : transparent;
        }
        Rectangle {
            background: board_state.last_move_from == i || board_state.last_move_to == i ? Palette.last_move_sq : transparent;
        }
        Rectangle {
            background: board_state.check_sq == i ? Palette.check_sq : transparent;
        }
        Image {
            height: parent.height;
            source: Utils.piece_urls[board_state.board[i]];
            visible: board_state.board[i] != 0 && board_state.dragged_piece_sq != i;
            width: parent.width;
        }
    }
    Image {
        height: Dimensions.sq_size;
        source: Utils.piece_urls[board_state.dragged_piece];
        visible: board_state.dragged_piece_sq != Utils.square_count;
        width: Dimensions.sq_size;
        x: Utils.constrain_mouse_x(parent.mouse-x) - (Dimensions.sq_size / 2);
        y: Utils.constrain_mouse_y(parent.mouse-y) - (Dimensions.sq_size / 2);
    }
    moved => {
        if (board_state.dragged_piece_sq == Utils.square_count) {
            RustInterface.begin_drag(RustInterface.square_from_xy(self.mouse-x, self.mouse-y, Dimensions.sq_size));
        }
    }
    clicked => {
        if (self.board_state.dragged_piece_sq != Utils.square_count) {
            if (self.board_state.dragged_piece != 0) {
                RustInterface.move_piece(self.board_state.dragged_piece_sq, RustInterface.square_from_xy(self.mouse-x, self.mouse-y, Dimensions.sq_size));
            }
        }
    }
}
